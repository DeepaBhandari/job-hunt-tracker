# Copy to .env (repo root) and fill in real values, or just run ./run.sh —
# it will generate this file for you on first run (reusing apps/api/.env
# values if present, otherwise generating fresh random secrets).

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=job_hunt_tracker

JWT_SECRET=
JWT_REFRESH_SECRET=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

FRONTEND_URL=http://localhost:3000
